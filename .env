# ============================================
# TRADING BOT PRO - Configuración de Claves
# ============================================
# 1. Copia este archivo y renómbralo a: .env
# 2. Rellena tus datos reales (nunca subas .env a GitHub)

# --- BYBIT TESTNET (para práctica, dinero ficticio) ---
BYBIT_TESTNET_API_KEY=tu_api_key_aqui
BYBIT_TESTNET_SECRET=tu_secret_aqui

# --- BYBIT PRODUCCIÓN (para dinero real, más adelante) ---
BYBIT_API_KEY=
BYBIT_SECRET=

# --- CONFIGURACIÓN DEL BOT ---
SYMBOL=BTC/USDT
TIMEFRAME=1h
MODO=testnet          # opciones: testnet | produccion

# --- TELEGRAM (opcional, para alertas) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
